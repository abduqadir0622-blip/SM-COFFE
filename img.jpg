<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400">
  <!-- Background -->
  <rect width="400" height="400" fill="#f5f5f5"/>
  
  <!-- Coffee Cup -->
  <g id="cup">
    <!-- Cup body -->
    <path d="M 80 120 L 100 280 Q 100 300 120 300 L 280 300 Q 300 300 300 280 L 320 120 Z" 
          fill="#8B4513" stroke="#5D2E0F" stroke-width="2"/>
    
    <!-- Cup highlight (shine) -->
    <ellipse cx="130" cy="160" rx="30" ry="50" fill="#A0522D" opacity="0.6"/>
    
    <!-- Steam wisps -->
    <path d="M 150 100 Q 145 80 155 60" stroke="#D2B48C" stroke-width="3" fill="none" stroke-linecap="round"/>
    <path d="M 200 110 Q 195 85 210 55" stroke="#D2B48C" stroke-width="3" fill="none" stroke-linecap="round"/>
    <path d="M 250 100 Q 245 80 260 60" stroke="#D2B48C" stroke-width="3" fill="none" stroke-linecap="round"/>
    
    <!-- Handle -->
    <path d="M 320 150 Q 360 150 360 220 Q 360 280 320 280" 
          fill="none" stroke="#8B4513" stroke-width="15" stroke-linecap="round"/>
  </g>
  
  <!-- Text: SM COFFE -->
  <text x="200" y="350" font-family="Arial, sans-serif" font-size="48" font-weight="bold" 
        text-anchor="middle" fill="#8B4513">SM COFFE</text>
  
  <!-- Decorative line -->
  <line x1="50" y1="365" x2="350" y2="365" stroke="#D2B48C" stroke-width="2"/>
</svg>